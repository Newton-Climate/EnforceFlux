*.png
# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
dist/
build/

# Outputs and run directories
outputs/
runs/

# macOS
.DS_Store

# Test cache and coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/

# Vendored upstream clones — nested git repos recreated by their make targets,
# never tracked here (see: make install-flexpart, make install-microhh)
/flexpart/
/microhh/

# FLEXPART build artifacts (redundant while /flexpart/ is ignored wholesale;
# kept so the rules survive if that directory is ever tracked again)
flexpart/src/*.o
flexpart/src/*.mod
flexpart/src/FLEXPART
flexpart/src/FLEXPART_ETA
flexpart/tests/testdata/
flexpart/tests/__pycache__/

# Vendored AtmosTransport.jl clone (a nested git repo, like /microhh/)
/AtmosTransport.jl/

# Slide-generation tooling
node_modules/

# Documents and generated decks — reference papers, exported presentations.
# Nothing of these types is tracked; narrow these if a doc should be versioned.
*.pdf
*.pptx
*.docx
*.pptx.inspect.ndjson

# Editor and agent scratch
.idea/
.vscode/
.codex/
