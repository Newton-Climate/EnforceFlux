{
  "random_seed": 7,
  "domain": {
    "x_min": 0,
    "x_max": 1000,
    "y_min": 0,
    "y_max": 1000,
    "grid_spacing": 250,
    "crs": "EPSG:32610",
    "crs_wgs84": "EPSG:4326"
  },
  "components": {
    "source": {
      "plugin": "enforceflux.source.static",
      "config": {
        "sources": [
          {
            "id": "S1",
            "kind": "point",
            "x": 200,
            "y": 300,
            "flux_true": 1.2,
            "flux_prior_mean": 0.4,
            "flux_prior_std": 0.6
          },
          {
            "id": "S2",
            "kind": "area",
            "x": 700,
            "y": 600,
            "flux_true": 0.8,
            "flux_prior_mean": 0.5,
            "flux_prior_std": 0.5
          }
        ]
      }
    },
    "instrument": {
      "plugin": "enforceflux.instrument.static",
      "config": {
        "instruments": [
          {
            "id": "I1",
            "kind": "open_path",
            "x": 400,
            "y": 300,
            "noise_std": 0.05,
            "averaging_seconds": 60
          },
          {
            "id": "I2",
            "kind": "open_path",
            "x": 800,
            "y": 400,
            "noise_std": 0.05,
            "averaging_seconds": 60
          },
          {
            "id": "I3",
            "kind": "flux_chamber",
            "x": 200,
            "y": 800,
            "noise_std": 0.08,
            "averaging_seconds": 120
          }
        ]
      }
    },
    "transport_operator": {
      "plugin": "enforceflux.transport_operator.aermod",
      "config": {
        "met": [
          {
            "wind_speed_m_s": 3.0,
            "wind_direction_deg": 270.0,
            "stability_class": "D",
            "mixing_height_m": 800.0
          },
          {
            "wind_speed_m_s": 3.0,
            "wind_direction_deg": 315.0,
            "stability_class": "C",
            "mixing_height_m": 800.0
          },
          {
            "wind_speed_m_s": 3.0,
            "wind_direction_deg": 180.0,
            "stability_class": "D",
            "mixing_height_m": 800.0
          },
          {
            "wind_speed_m_s": 3.0,
            "wind_direction_deg": 105.0,
            "stability_class": "E",
            "mixing_height_m": 800.0
          }
        ],
        "default_stack": {
          "height_m": 5.0
        },
        "concentration_units": "ug_m3_per_g_s"
      }
    },
    "inversion": {
      "plugin": "enforceflux.inversion.bayesian",
      "config": {
        "r_cond": 1e-06
      }
    }
  }
}
